[Unit]
Description=Windscribe Gateway Container
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/root/windscribe-gw
ExecStart=/bin/bash -c 'docker compose up -d && sleep 60'
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=180

[Install]
WantedBy=multi-user.target
