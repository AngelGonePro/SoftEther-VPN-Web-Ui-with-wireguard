# ════════════════════════════════════════════════════════════════════
# VPN SERVER CONFIGURATION
# Copy this file to .env and edit before running docker compose up -d
# ════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────
SERVER_IP=45.79.25.46           # Your server public IP or domain

# ── SoftEther Credentials ─────────────────────────────────────────────
SE_SERVER_PASSWORD=ChangeMe_ServerPassword!
SE_HUB_PASSWORD=ChangeMe_HubPassword!
SE_USERS=vpnuser:ChangeMe_UserPassword!
SE_PSK=ChangeMe_PreSharedKey!

# ── SoftEther Ports ───────────────────────────────────────────────────
PORT_OVPN_UDP=9194
PORT_OVPN_TCP=8443
PORT_SSL_ALT=9992
PORT_L2TP=9701
PORT_IKEV2=9000
PORT_IKEV2_NAT=9500
PORT_JSONRPC=9555
PORT_WEBUI=9765

# ── WireGuard ──────────────────────────────────────────────────────────
PORT_WIREGUARD=51822
WG_PEERS=5

# ── WireGuard API ──────────────────────────────────────────────────────
# Random secret key — change this to something secure!
WG_API_KEY=ChangeMe_WgApiKey!

# ════════════════════════════════════════════════════════════════════
# After editing ports here, also update CFG block in ui/index.html!
# ════════════════════════════════════════════════════════════════════
